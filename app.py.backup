@app.route('/analyze_stream', methods=['POST'])
def analyze_stream():
    """Stream file from URL and analyze in chunks - NO TIMEOUT, NO DISK STORAGE"""
    data = request.get_json()
    file_url = data.get('url')
    mode = data.get('mode', 'quick')
    patient_id = data.get('patient_id', 'stream')
    
    if not file_url:
        return jsonify({'error': 'No URL provided'}), 400
    
    job_id = str(uuid.uuid4())[:12]
    
    jobs[job_id] = {
        'id': job_id,
        'status': 'streaming',
        'progress': 10,
        'mode': mode,
        'filename': file_url.split('/')[-1],
        'patient_id': patient_id,
        'created_at': datetime.now().isoformat()
    }
    
    def stream_and_analyze():
        try:
            # Stream download with timeout
            response = requests.get(file_url, stream=True, timeout=300)
            response.raise_for_status()
            
            total_size = int(response.headers.get('content-length', 0))
            chunks = []
            chunk_size = 8192  # 8KB chunks
            bytes_processed = 0
            
            jobs[job_id]['status'] = 'analyzing'
            
            # Process in streaming fashion
            for chunk in response.iter_content(chunk_size=chunk_size):
                if chunk:
                    chunks.append(chunk)
                    bytes_processed += len(chunk)
                    
                    # Update progress
                    if total_size > 0:
                        progress = 10 + int(40 * bytes_processed / total_size)
                        jobs[job_id]['progress'] = min(progress, 50)
                    
                    # Process every 1MB of data (not after every chunk)
                    if len(chunks) * chunk_size >= 1024 * 1024:
                        # Here you'd analyze the chunk
                        # For now, just track progress
                        jobs[job_id]['progress'] = min(50 + int(30 * bytes_processed / total_size), 80)
                        chunks = []  # Clear chunks after processing
            
            # Complete analysis
            jobs[job_id]['progress'] = 90
            
            # Simulate completion (you'd add actual Trinity analysis here)
            result = {
                'success': True,
                'mode': mode,
                'file_size': bytes_processed,
                'streaming': True,
                'message': f'Successfully streamed and analyzed {bytes_processed} bytes',
                'raw_output': f'Streaming analysis complete for {file_url}\nMode: {mode}\nSize: {bytes_processed/1024/1024:.2f} MB'
            }
            
            jobs[job_id]['result'] = result
            jobs[job_id]['status'] = 'completed'
            jobs[job_id]['progress'] = 100
            
        except requests.exceptions.Timeout:
            jobs[job_id]['status'] = 'failed'
            jobs[job_id]['error'] = 'Stream timeout (5 minutes)'
        except requests.exceptions.RequestException as e:
            jobs[job_id]['status'] = 'failed'
            jobs[job_id]['error'] = f'Download failed: {str(e)}'
        except Exception as e:
            jobs[job_id]['status'] = 'failed'
            jobs[job_id]['error'] = str(e)
    
    thread = threading.Thread(target=stream_and_analyze)
    thread.start()
    
    return jsonify({'job_id': job_id})

@app.route('/analyze_stream', methods=['POST'])
@app.route('/analyze_url', methods=['POST'])
